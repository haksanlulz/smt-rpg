<section class="smt-actor-sheet {{actorType}}">
  {{!-- Header --}}
  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" title="{{actor.name}}" data-action="editImage" />
    <div class="header-fields">
      <h1 class="actor-name">
        <input name="name" type="text" value="{{actor.name}}" placeholder="{{localize 'SMT.Name'}}" />
      </h1>
      <div class="header-row">
        <span class="actor-class">{{localize classLabel}}</span>
        {{#if isHuman}}
          <div class="resource">
            <select name="system.subclass">
              {{#each @root.subclassChoices as |label key|}}
                <option value="{{key}}" {{#if (eq key ../system.subclass)}}selected{{/if}}>{{localize label}}</option>
              {{/each}}
            </select>
          </div>
        {{/if}}
        {{#if isDemon}}
          <div class="resource">
            <label>{{localize "SMT.Clan"}}</label>
            <select name="system.clan">
              {{#each @root.clanChoices as |label key|}}
                <option value="{{key}}" {{#if (eq key ../system.clan)}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
          </div>
          <div class="resource">
            <label>{{localize "SMT.FavoredStat"}}</label>
            <select name="system.favoredStat">
              <option value="" {{#unless system.favoredStat}}selected{{/unless}}>—</option>
              {{#each @root.statChoices as |label key|}}
                <option value="{{key}}" {{#if (eq key ../system.favoredStat)}}selected{{/if}}>{{localize label}}</option>
              {{/each}}
            </select>
          </div>
        {{/if}}
      </div>
      <div class="header-row resource-row">
        <div class="resource">
          <label>{{localize "SMT.Level"}}</label>
          <input type="number" name="system.level" value="{{system.level}}" />
        </div>
        <div class="resource">
          <label>{{localize "SMT.EXP"}}</label>
          <input type="number" name="system.exp" value="{{system.exp}}" />
        </div>
        <div class="resource">
          <label>{{localize "SMT.Next"}}</label>
          <span class="{{#if system.canLevelUp}}exp-ready{{/if}}">{{system.expNext}}</span>
        </div>
        {{!-- EXP-ready level-up control (p.48); shown once canLevelUp. --}}
        {{#if system.canLevelUp}}
        <div class="resource level-up">
          <button type="button" class="level-up-btn" data-action="levelUp"
            data-tooltip="{{localize 'SMT.LevelUp.Hint'}}">
            <i class="fas fa-arrow-up"></i> {{localize "SMT.LevelUp.Action"}}
          </button>
        </div>
        {{/if}}
        <div class="resource">
          <label>{{localize "SMT.Macca"}}</label>
          <input type="number" name="system.macca" value="{{system.macca}}" />
        </div>
      </div>
      {{> "systems/smt-rpg/templates/actor/partials/conditions.hbs"}}
    </div>
  </header>

  {{!-- Navigation Tabs --}}
  <nav class="sheet-tabs">
    <a class="item {{#if (eq activeTab 'combat')}}active{{/if}}" data-tab="combat" data-action="switchTab">{{localize "SMT.Tab.Combat"}}</a>
    <a class="item {{#if (eq activeTab 'skills')}}active{{/if}}" data-tab="skills" data-action="switchTab">{{localize "SMT.Tab.Skills"}}</a>
    {{#if isFiend}}
      <a class="item {{#if (eq activeTab 'magatama')}}active{{/if}}" data-tab="magatama" data-action="switchTab">{{localize "SMT.Tab.Magatama"}}</a>
    {{/if}}
    {{#if isHuman}}
      <a class="item {{#if (eq activeTab 'gear')}}active{{/if}}" data-tab="gear" data-action="switchTab">{{localize "SMT.Tab.Gear"}}</a>
    {{/if}}
    <a class="item {{#if (eq activeTab 'inventory')}}active{{/if}}" data-tab="inventory" data-action="switchTab">{{localize "SMT.Tab.Inventory"}}</a>
    <a class="item {{#if (eq activeTab 'effects')}}active{{/if}}" data-tab="effects" data-action="switchTab">{{localize "SMT.Tab.Effects"}}</a>
    <a class="item {{#if (eq activeTab 'bio')}}active{{/if}}" data-tab="bio" data-action="switchTab">{{localize "SMT.Tab.Bio"}}</a>
  </nav>

  {{!-- Tab Content --}}
  <section class="sheet-body">

    {{!-- COMBAT TAB --}}
    <div class="tab combat {{#if (eq activeTab 'combat')}}active{{/if}}" data-tab="combat">
      {{> "systems/smt-rpg/templates/actor/partials/combat.hbs"}}
      {{> "systems/smt-rpg/templates/actor/partials/stats.hbs"}}
      {{> "systems/smt-rpg/templates/actor/partials/affinities.hbs"}}
    </div>

    {{!-- SKILLS TAB --}}
    <div class="tab skills {{#if (eq activeTab 'skills')}}active{{/if}}" data-tab="skills">
      {{> "systems/smt-rpg/templates/actor/partials/skills.hbs"}}
    </div>

    {{!-- MAGATAMA TAB (Fiend only) --}}
    {{#if isFiend}}
    <div class="tab magatama {{#if (eq activeTab 'magatama')}}active{{/if}}" data-tab="magatama">
      <a class="add-item-btn" data-action="createItem" data-type="magatama"><i class="fas fa-plus"></i> {{localize "SMT.AddMagatama"}}</a>
      <div class="items-list">
        <div class="items-header">
          <span class="item-name">{{localize "SMT.Name"}}</span>
          <span class="item-detail">{{localize "SMT.Active"}}</span>
          <span class="item-controls"></span>
        </div>
        {{#each magatamas as |mag|}}
        <div class="item" data-item-id="{{mag._id}}">
          <span class="item-name clickable" data-action="viewItem">{{mag.name}}</span>
          <span class="item-detail">
            <input type="radio" name="system.activeMagatama" value="{{mag._id}}"
              {{#if (eq mag._id ../system.activeMagatama)}}checked{{/if}} />
          </span>
          <span class="item-controls">
            <a class="item-control" data-action="editItem" title="Edit"><i class="fas fa-edit"></i></a>
            <a class="item-control" data-action="deleteItem" title="Delete"><i class="fas fa-trash"></i></a>
          </span>
        </div>
        {{/each}}
      </div>
    </div>
    {{/if}}

    {{!-- GEAR TAB (Human only) --}}
    {{#if isHuman}}
    <div class="tab gear {{#if (eq activeTab 'gear')}}active{{/if}}" data-tab="gear">
      <a class="add-item-btn" data-action="createItem" data-type="gear"><i class="fas fa-plus"></i> {{localize "SMT.AddGear"}}</a>
      <div class="items-list">
        <div class="items-header">
          <span class="item-name">{{localize "SMT.Name"}}</span>
          <span class="item-detail">{{localize "SMT.GearType.Label"}}</span>
          <span class="item-detail">{{localize "SMT.Power"}}</span>
          <span class="item-detail">{{localize "SMT.Equipped"}}</span>
          <span class="item-controls"></span>
        </div>
        {{#each gear as |item|}}
        <div class="item" data-item-id="{{item._id}}">
          <span class="item-name clickable" data-action="viewItem">{{item.name}}</span>
          <span class="item-detail">{{localize (lookup @root.gearTypeLabels item.system.gearType)}}</span>
          <span class="item-detail">{{item.system.powerBonus}}</span>
          <span class="item-detail">
            <input type="checkbox" data-action="toggleEquip" {{#if item.system.equipped}}checked{{/if}} />
          </span>
          <span class="item-controls">
            <a class="item-control" data-action="editItem" title="Edit"><i class="fas fa-edit"></i></a>
            <a class="item-control" data-action="deleteItem" title="Delete"><i class="fas fa-trash"></i></a>
          </span>
        </div>
        {{/each}}
      </div>
    </div>
    {{/if}}

    {{!-- INVENTORY TAB --}}
    <div class="tab inventory {{#if (eq activeTab 'inventory')}}active{{/if}}" data-tab="inventory">
      <a class="add-item-btn" data-action="createItem" data-type="consumable"><i class="fas fa-plus"></i> {{localize "SMT.AddItem"}}</a>
      <div class="items-list">
        <div class="items-header">
          <span class="item-name">{{localize "SMT.Name"}}</span>
          <span class="item-detail">{{localize "SMT.Type"}}</span>
          <span class="item-detail">{{localize "SMT.Quantity"}}</span>
          <span class="item-controls"></span>
        </div>
        {{#each consumables as |item|}}
        <div class="item" data-item-id="{{item._id}}">
          <span class="item-name clickable" data-action="viewItem">{{item.name}}</span>
          <span class="item-detail">{{localize (lookup @root.consumableTypeLabels item.system.consumableType)}}</span>
          <span class="item-detail">
            <input type="number" value="{{item.system.quantity}}" data-action="updateQuantity" min="0" />
          </span>
          <span class="item-controls">
            <a class="item-control" data-action="useItem" title="Use"><i class="fas fa-flask"></i></a>
            <a class="item-control" data-action="editItem" title="Edit"><i class="fas fa-edit"></i></a>
            <a class="item-control" data-action="deleteItem" title="Delete"><i class="fas fa-trash"></i></a>
          </span>
        </div>
        {{/each}}
      </div>
    </div>

    {{!-- EFFECTS TAB --}}
    <div class="tab effects {{#if (eq activeTab 'effects')}}active{{/if}}" data-tab="effects">
      {{> "systems/smt-rpg/templates/actor/partials/effects.hbs"}}
    </div>

    {{!-- BIO TAB --}}
    <div class="tab bio {{#if (eq activeTab 'bio')}}active{{/if}}" data-tab="bio">
      {{#if isDemon}}
      <div class="npc-behavior">
        <h3>{{localize "SMT.EvolvePath"}}</h3>
        <div class="form-row">
          <div class="form-group">
            <label>{{localize "SMT.EvolveDemon"}}</label>
            <input type="text" name="system.evolvePath.demonName" value="{{system.evolvePath.demonName}}" />
          </div>
          <div class="form-group">
            <label>{{localize "SMT.EvolveLevel"}}</label>
            <input type="number" name="system.evolvePath.level" value="{{system.evolvePath.level}}" min="0" />
          </div>
          <div class="form-group">
            <label>{{localize "SMT.EvolvePartyLevel"}}</label>
            <input type="number" name="system.evolvePath.partyLevel" value="{{system.evolvePath.partyLevel}}" min="0" />
          </div>
        </div>
      </div>
      {{/if}}
      <div class="bio-fields">
        <div class="form-group full-width">
          <label>{{localize "SMT.Background"}} 1</label>
          <div class="editor-container">
            <prose-mirror name="system.background1" value="{{system.background1}}" button="true" toggled="false">{{{enriched.background1}}}</prose-mirror>
          </div>
        </div>
        <div class="form-group full-width">
          <label>{{localize "SMT.Background"}} 2</label>
          <div class="editor-container">
            <prose-mirror name="system.background2" value="{{system.background2}}" button="true" toggled="false">{{{enriched.background2}}}</prose-mirror>
          </div>
        </div>
        <div class="form-group full-width">
          <label>{{localize "SMT.Goal"}}</label>
          <div class="editor-container">
            <prose-mirror name="system.goal" value="{{system.goal}}" button="true" toggled="false">{{{enriched.goal}}}</prose-mirror>
          </div>
        </div>
        <div class="form-group full-width">
          <label>{{localize "SMT.Contacts"}}</label>
          <div class="editor-container">
            <prose-mirror name="system.contacts" value="{{system.contacts}}" button="true" toggled="false">{{{enriched.contacts}}}</prose-mirror>
          </div>
        </div>
        <div class="form-group full-width">
          <label>{{localize "SMT.Bonds"}}</label>
          <div class="editor-container">
            <prose-mirror name="system.bonds" value="{{system.bonds}}" button="true" toggled="false">{{{enriched.bonds}}}</prose-mirror>
          </div>
        </div>
        <div class="form-group full-width">
          <label>{{localize "SMT.Notes"}}</label>
          <div class="editor-container large">
            <prose-mirror name="system.notes" value="{{system.notes}}" button="true" toggled="false">{{{enriched.notes}}}</prose-mirror>
          </div>
        </div>
      </div>
    </div>

  </section>
</section>
